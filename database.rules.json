{
  "rules": {
    "ithopiia": {
      ".read": "auth != null",
      ".write": "auth != null",
      "roles": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth.uid === $uid"
        }
      },
      "settings": {
        ".read": "auth != null",
        ".write": "root.child('ithopiia/users/' + auth.uid + '/role').val() === 'admin' || root.child('ithopiia/users/' + auth.uid + '/role').val() === 'member'"
      }
    }
  }
}
